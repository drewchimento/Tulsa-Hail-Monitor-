# Copy this file to .env and fill in real values for local testing.
# In production, these come from GitHub Secrets, not from a .env file.

RESEND_API_KEY=re_replace_with_your_resend_api_key
ALERT_TO_EMAIL=drew@bytedreams.ai

# Optional: override the From address. Default is onboarding@resend.dev,
# which works on Resend's free tier without domain verification.
# RESEND_FROM_EMAIL=alerts@bytedreams.ai
